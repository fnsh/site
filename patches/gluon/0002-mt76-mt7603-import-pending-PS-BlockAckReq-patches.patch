++
+diff --git a/package/kernel/mt76/patches/0502-wifi-mt76-mt7603-enable-SW-tracking-for-BlockAckReq-.patch b/package/kernel/mt76/patches/0502-wifi-mt76-mt7603-enable-SW-tracking-for-BlockAckReq-.patch
+new file mode 100644
+index 0000000000000000000000000000000000000000..4c4f7d3feeb0799a294b664877f67684b6395145
+--- /dev/null
++++ b/package/kernel/mt76/patches/0502-wifi-mt76-mt7603-enable-SW-tracking-for-BlockAckReq-.patch
+@@ -0,0 +1,27 @@
++From 5eff0c1b21462be0085074ec26b83cf8a647708f Mon Sep 17 00:00:00 2001
++From: David Bauer <mail@david-bauer.net>
++Date: Sun, 7 Jun 2026 14:03:59 +0200
++Subject: [PATCH 502/504] wifi: mt76: mt7603: enable SW tracking for
++ BlockAckReq ACK state
++
++Signed-off-by: David Bauer <mail@david-bauer.net>
++---
++ mt7603/init.c | 2 +-
++ 1 file changed, 1 insertion(+), 1 deletion(-)
++
++diff --git a/mt7603/init.c b/mt7603/init.c
++index b78e75bc..e8bbb7d2 100644
++--- a/mt7603/init.c
+++++ b/mt7603/init.c
++@@ -7,7 +7,7 @@
++ 
++ const struct mt76_driver_ops mt7603_drv_ops = {
++ 	.txwi_size = MT_TXD_SIZE,
++-	.drv_flags = MT_DRV_SW_RX_AIRTIME,
+++	.drv_flags = MT_DRV_SW_RX_AIRTIME | MT_DRV_MANUAL_BAR_TRACKING,
++ 	.survey_flags = SURVEY_INFO_TIME_TX,
++ 	.tx_prepare_skb = mt7603_tx_prepare_skb,
++ 	.tx_complete_skb = mt7603_tx_complete_skb,
++-- 
++2.53.0
++
+diff --git a/package/kernel/mt76/patches/0503-wifi-mt76-send-BAR-before-queued-frame-TX-after-PS.patch b/package/kernel/mt76/patches/0503-wifi-mt76-send-BAR-before-queued-frame-TX-after-PS.patch
+new file mode 100644
+index 0000000000000000000000000000000000000000..7b8f8859cffc590fc0e874fd420a537e136447df
+--- /dev/null
++++ b/package/kernel/mt76/patches/0503-wifi-mt76-send-BAR-before-queued-frame-TX-after-PS.patch
+@@ -0,0 +1,90 @@
++From b540b98861f54d970c4203433f57c8cb9186feae Mon Sep 17 00:00:00 2001
++From: David Bauer <mail@david-bauer.net>
++Date: Sat, 30 May 2026 09:38:41 +0200
++Subject: [PATCH 503/504] wifi: mt76: send BAR before queued frame TX after PS
++
++mt7603, mt7610 and mt7612 send a BlockAckReq to a STA leaving powersave.
++The current way this is implemented however is by putting the frame in
++the regular queue.
++
++This way, the BlockAckReq is sent after the pending data frames with an
++outdated SSN. This can recover itself, however especially with Apple
++devices this can cause excessive jitter in downstream for the user.
++
++Work around this by forwarding the BlockAckReq to hardware before
++delivering data frames.
++
++Signed-off-by: David Bauer <mail@david-bauer.net>
++---
++ tx.c | 46 ++++++++++++++++++++++++++++++++++++++++++++--
++ 1 file changed, 44 insertions(+), 2 deletions(-)
++
++diff --git a/tx.c b/tx.c
++index 74c67ea8..2f6f2cb3 100644
++--- a/tx.c
+++++ b/tx.c
++@@ -498,6 +498,49 @@ mt76_txq_stopped(struct mt76_queue *q)
++ 	       q->queued + MT_TXQ_FREE_THR >= q->ndesc;
++ }
++ 
+++static void
+++mt76_send_bar(struct mt76_dev *dev, struct ieee80211_vif *vif,
+++	      struct ieee80211_sta *sta, struct ieee80211_txq *txq,
+++	      u16 ssn)
+++{
+++	struct ieee80211_hw *hw = dev->phy.hw;
+++	struct mt76_wcid *wcid = (struct mt76_wcid *)sta->drv_priv;
+++	struct sk_buff *skb;
+++	struct ieee80211_bar *bar;
+++	u16 bar_control = 0;
+++	struct mt76_queue *q;
+++
+++
+++	skb = dev_alloc_skb(sizeof(*bar) + hw->extra_tx_headroom);
+++	if (!skb)
+++		return;
+++
+++	skb_reserve(skb, hw->extra_tx_headroom);
+++	bar = skb_put_zero(skb, sizeof(*bar));
+++	bar->frame_control = cpu_to_le16(IEEE80211_FTYPE_CTL |
+++					 IEEE80211_STYPE_BACK_REQ);
+++	memcpy(bar->ra, sta->addr, ETH_ALEN);
+++	memcpy(bar->ta, vif->addr, ETH_ALEN);
+++	bar_control |= (u16)IEEE80211_BAR_CTRL_ACK_POLICY_NORMAL;
+++	bar_control |= (u16)IEEE80211_BAR_CTRL_CBMTID_COMPRESSED_BA;
+++	bar_control |= (u16)(txq->tid << IEEE80211_BAR_CTRL_TID_INFO_SHIFT);
+++	bar->control = cpu_to_le16(bar_control);
+++	bar->start_seq_num = cpu_to_le16(ssn);
+++
+++	IEEE80211_SKB_CB(skb)->flags |= IEEE80211_TX_INTFL_DONT_ENCRYPT |
+++					IEEE80211_TX_CTL_REQ_TX_STATUS;
+++	
+++	skb_set_queue_mapping(skb, txq->ac);
+++
+++	/* Direct TX */
+++	q = dev->phy.q_tx[txq->ac];
+++	spin_lock(&q->lock);
+++	__mt76_tx_queue_skb(&dev->phy, txq->ac, skb, wcid, sta, NULL);
+++	dev->queue_ops->kick(dev, q);
+++	spin_unlock(&q->lock);
+++}
+++
+++
++ static int
++ mt76_txq_send_burst(struct mt76_phy *phy, struct mt76_queue *q,
++ 		    struct mt76_txq *mtxq, struct mt76_wcid *wcid)
++@@ -627,10 +670,9 @@ mt76_txq_schedule_list(struct mt76_phy *phy, enum mt76_txq_id qid)
++ 			struct ieee80211_sta *sta = txq->sta;
++ 			struct ieee80211_vif *vif = txq->vif;
++ 			u16 agg_ssn = mtxq->agg_ssn;
++-			u8 tid = txq->tid;
++ 
++ 			mtxq->send_bar = false;
++-			ieee80211_send_bar(vif, sta->addr, tid, agg_ssn);
+++			mt76_send_bar(dev, vif, sta, txq, agg_ssn);
++ 		}
++ 
++ 		if (!mt76_txq_stopped(q))
++-- 
